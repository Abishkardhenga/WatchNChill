{
  "compilerOptions": {
    "target": "ES6", // or a modern version like ES2020
    "module": "commonjs", // Node.js uses CommonJS modules
    "strict": true, // Enable strict type-checking for better code quality
    "esModuleInterop": true, // Allows interoperability between CommonJS and ES modules
    "skipLibCheck": true, // Skip type checking of declaration files
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist", // Directory for compiled JavaScript files
    "rootDir": "./src" // Directory for your TypeScript source files
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
